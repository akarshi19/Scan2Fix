# ============================================================
# Scan2Fix Mobile App — Environment Variables
# Copy this file to .env and fill in the value before building
# ============================================================

# ── Server URL ───────────────────────────────────────────────
# Must end with /api — no trailing slash.
#
# Local (Android emulator):   http://10.0.2.2:5000/api
# Local (physical device):    http://192.168.X.X:5000/api   ← your machine's LAN IP
# Production (ngrok):         https://your-subdomain.ngrok-free.app/api
API_URL=https://your-subdomain.ngrok-free.app/api

# ── EAS / GitHub Actions (CI only — not needed on device) ───
# Expo account token for eas build in GitHub Actions.
# Generate at: https://expo.dev/accounts/<user>/settings/access-tokens
# Add as a GitHub repo secret named EXPO_TOKEN — do NOT commit this value.
# EXPO_TOKEN=
