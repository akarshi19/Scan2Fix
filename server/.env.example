# ============================================================
# Scan2Fix Server — Environment Variables
# Copy this file to .env and fill in every value before start
# ============================================================

# ── MongoDB ─────────────────────────────────────────────────
# Local Windows install:  mongodb://localhost:27017/scan2fix
# MongoDB Atlas:          mongodb+srv://<user>:<pass>@cluster.mongodb.net/scan2fix
MONGO_URI=mongodb://localhost:27017/scan2fix

# ── JWT ─────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string
JWT_EXPIRE=30d

# ── Server ──────────────────────────────────────────────────
PORT=5000
# development | production
NODE_ENV=production

# ── Email (Gmail SMTP) ───────────────────────────────────────
# Use a Gmail App Password — NOT your normal Gmail password.
# Enable at: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM_NAME=Scan2Fix
